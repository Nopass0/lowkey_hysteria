# Lowkey Hysteria VPN server

# Public node identity
SERVER_IP=203.0.113.10
SERVER_HOSTNAME=s1.lowkey.su

# UDP port for the Hysteria listener
LISTEN_ADDR=:443

# Optional HTTP API bind
HTTP_ADDR=:8080

# TCP port for VLESS/Xray
XRAY_PORT=443

# Shared VoidDB connection
VOIDDB_URL=https://db.lowkey.su
VOIDDB_USERNAME=admin
VOIDDB_PASSWORD=admin
VOIDDB_TOKEN=

# Shared JWT secret used by clients/site/bot
JWT_SECRET=super-secret-key

# Optional central backend URL
BACKEND_URL=https://lowkey.su/api

# Hysteria TLS certificate
CERT_FILE=/etc/letsencrypt/live/s1.lowkey.su/fullchain.pem
KEY_FILE=/etc/letsencrypt/live/s1.lowkey.su/privkey.pem

# Optional PM2 process name used by scripts/pm2_start.sh
PM2_APP_NAME=hysteria-s1

# Optional MTProto proxy branch
MTPROTO_ENABLED=false
MTPROTO_PORT=8443
MTPROTO_SECRET=dd0123456789abcdef0123456789abcdef
MTPROTO_AD_TAG=
MTPROTO_CHANNEL_USERNAME=@lowkeyvpn
MTPROTO_BOT_USERNAME=@lowkeyvpnbot
MTPROTO_ADD_CHANNEL=false

TOCHKA_API_KEY=
TOCHKA_MERCHANT_ID=
TOCHKA_ACCOUNT_ID=
