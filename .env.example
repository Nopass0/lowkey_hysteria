# ─── Lowkey Hysteria2 VPN Server ───────────────────────────────────────────────
#
# This service authenticates VPN users DIRECTLY via PostgreSQL + Redis.
# It works independently even if the main backend website is unavailable.
# The backend API (BACKEND_URL) is only used for optional server registration
# and heartbeat reporting — NOT for authentication.
#
# The public IP of this server is detected automatically at startup.

# UDP port Hysteria2 listens on (open this in firewall: sudo ufw allow 7000/udp)
LISTEN_ADDR=:7000

# PostgreSQL connection string (same DB as the backend)
DATABASE_URL=postgres://user:password@localhost:5432/lowkey

# Redis connection string (same Redis as the backend)
REDIS_URL=redis://localhost:6379

# URL of the central Lowkey backend API (for server registration/heartbeat only)
BACKEND_URL=https://api.lowkey.example.com

TOCHKA_API_KEY=
TOCHKA_MERCHANT_ID=
TOCHKA_ACCOUNT_ID=
BACKEND_URL=