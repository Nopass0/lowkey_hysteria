# ─── Lowkey Hysteria2 VPN Server ───────────────────────────────────────────────
#
# NOTE: This service does NOT connect to Postgres or Redis directly.
#       All DB logic runs in the ElysiaJS backend (see backend/.env).
#       This Go server only communicates with the backend via HTTP API.
#
# The public IP of this server is detected automatically at startup.
# You only need to set the backend URL and the listen port.

# UDP port Hysteria2 listens on (open this in firewall: sudo ufw allow 7000/udp)
LISTEN_ADDR=:7000

# URL of the central Lowkey backend API (no trailing slash)
BACKEND_URL=https://api.lowkey.example.com
